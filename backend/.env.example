# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# MongoDB (Atlas connection string recommended for production)
MONGODB_URI=mongodb://127.0.0.1:27017/voyager

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Google OAuth (Google Cloud Console -> OAuth 2.0 Client ID, Web application)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Demo account (auto-provisioned by the seed script and used by the "Demo login" button)
DEMO_USER_EMAIL=demo@voyager.app
DEMO_USER_PASSWORD=DemoPass123!

# Gemini (Google AI Studio -> Get API key)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-flash-latest
